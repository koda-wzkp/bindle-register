{
  "name": "@bindle/core",
  "version": "0.1.0",
  "description": "Bindle core primitives: canonicalization, PUID, validation, glyph. Pure functions, no I/O.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "default": "./dist/validate.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "default": "./dist/policy.js"
    },
    "./glyph": {
      "types": "./dist/glyph.d.ts",
      "default": "./dist/glyph.js"
    }
  },
  "bin": {
    "bindle-verify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "canonicalize": "^2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
