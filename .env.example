# --- Supabase (Puddletown's account) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never exposed to the client bundle; used exclusively in route
# handlers and server components (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend (Puddletown's account) ---
RESEND_API_KEY=re_...
# Verified sender, e.g. "Bindle Register <register@puddletowntheatre.org>"
EMAIL_FROM="Bindle Register <register@example.org>"

# --- App ---
# Absolute origin used in emailed links, e.g. https://register.puddletowntheatre.org
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated allowlist of admin emails (v1 has no roles table; don't build one)
ADMIN_EMAILS=chase@example.org,treasurer@example.org
# Name of the single tenant organization; the app boots it on first use
ORG_NAME=Puddletown Theatre Collective

# DECIDE-04 gate: the consent text (lib/consent.ts) has NOT had legal review.
# Production deployments refuse to record signatures until counsel signs off
# and this is set to true. Preview/UAT environments can sign with dummy data.
CONSENT_TEXT_REVIEWED=false

# Supabase project auth settings (dashboard, not env): set "Email OTP
# expiration" to 3600 (1 hour). See lib/magiclink.ts for the reasoning.
